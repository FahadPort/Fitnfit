{
  "functions": {
    "server.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server.ts"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/server.ts"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
